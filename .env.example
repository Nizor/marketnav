# Copy this file to .env and fill in your values.
# Never commit .env to version control.

SECRET_KEY=your-very-secret-key-change-this

DEBUG=True

# Comma-separated list of allowed hosts in production
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DB_NAME=marketnav
DB_USER=marketnav_user
DB_PASSWORD=marketnav_pass
DB_HOST=localhost
DB_PORT=5432

# CORS (set to False in production and list specific origins)
CORS_ALLOW_ALL=True
CORS_ALLOWED_ORIGINS=https://yourdomain.com

# Base URL for QR code generation (used in admin action)
SITE_BASE_URL=https://marketnav.ng
